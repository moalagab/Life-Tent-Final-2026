# ── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY

# ── PostHog Product Analytics (optional — leave blank to disable) ─────────────
# Get your key at https://app.posthog.com → Project Settings → Project API Key
VITE_POSTHOG_KEY=
# US cloud: https://us.i.posthog.com  |  EU cloud: https://eu.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Sentry (optional — leave blank to disable) ────────────────────────────────
VITE_SENTRY_DSN=

# ── App version (used by Sentry release tagging) ─────────────────────────────
VITE_APP_VERSION=1.0.0

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# 1. Generate keys:   node scripts/generate-vapid-keys.mjs
#    (or)             npx web-push generate-vapid-keys
# 2. Paste the PUBLIC key below (used at build time by the browser subscription):
VITE_VAPID_PUBLIC_KEY=

# 3. Add the following to Supabase Edge Function secrets (dashboard → Settings → Edge Functions):
#    VAPID_PUBLIC_KEY   = <same public key>
#    VAPID_PRIVATE_KEY  = <private key from step 1>
#    VAPID_SUBJECT      = mailto:your@email.com

# ── Supabase Edge Functions secrets (set in Supabase dashboard, not here) ────
# RESEND_API_KEY=re_xxxxx           # for send-notifications + send-welcome-email functions
# SUPABASE_SERVICE_ROLE_KEY=...     # for admin operations in edge functions
#
# ── Database settings required for welcome-email trigger ─────────────────────
# Run once in Supabase SQL editor:
#   ALTER DATABASE postgres SET "app.supabase_url"      = 'https://YOUR_PROJECT.supabase.co';
#   ALTER DATABASE postgres SET "app.service_role_key"  = 'YOUR_SERVICE_ROLE_KEY';
#
# Official contact email: info@lifetent.online
# All system emails sent FROM: Life Tent <info@lifetent.online>

# ── Gemini AI (set as Supabase secret for edge functions) ────────────────────
# GEMINI_API_KEY=AQ.xxxxx           # for ai-decision-engine function
